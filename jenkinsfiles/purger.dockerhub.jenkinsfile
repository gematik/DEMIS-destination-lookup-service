@Library('gematik-jenkins-shared-library') _
pipelineDockerHubPublish {
    DOCKER_CREDENTIALS = 'demis-qs-gar-writer'
    DOCKER_REPOSITORY = 'europe-west3-docker.pkg.dev/gematik-all-infra-prod'
    INTERNAL_IMAGE_NAME = 'demis-qs/destination-lookup-purger'
    EXTERNAL_IMAGE_NAME = 'gematik1/demis-destination-lookup-purger'
    SIGN_OIDC_CREDENTIALS = 'sa-image-signature-demis'
    SIGN_TYPE = 'OIDC-GOOGLE'
}